@{
    ViewData["Title"] = "Search";
    var embedUrl = ViewData["VideoUrl"] as string;
    var videoId = !string.IsNullOrEmpty(embedUrl) ? embedUrl.Split('/').Last().Split('?').First() : null;
}

<div class="row">
    <!-- Video Player -->
    <div class="col-12 col-md-7 col-lg-8 mb-3">
        <div class="ratio ratio-16x9 bg-dark rounded">
            @if (!string.IsNullOrEmpty(videoId))
            {
                <div id="ytplayer"></div>
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center text-white">
                    <span>Video Player</span>
                </div>
            }
        </div>
    </div>

    <!-- Tabbed Panel -->
    <div class="col-12 col-md-5 col-lg-4">
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="myNotesOnly">
            <label class="form-check-label" for="myNotesOnly">Show only my notes</label>
        </div>
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="view-tab" data-bs-toggle="tab"
                        data-bs-target="#view-pane" type="button" role="tab"
                        aria-controls="view-pane" aria-selected="true">View</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="comment-tab" data-bs-toggle="tab"
                        data-bs-target="#comment-pane" type="button" role="tab"
                        aria-controls="comment-pane" aria-selected="false">Comment</button>
            </li>
        </ul>
        <div class="tab-content border border-top-0 rounded-bottom p-3">
            <!-- View Tab -->
            <div class="tab-pane fade show active" id="view-pane" role="tabpanel" aria-labelledby="view-tab">
                @if (ViewData["Notes"] is youtube_notes.Models.Note[] notes && notes.Length > 0)
                {
                    @foreach (var note in notes)
                    {
                        <div class="mb-2 p-2 border rounded comment-marker" data-time="@note.TimeAt" data-email="@note.User?.Email">
                            <small class="text-muted fw-bold">@note.User?.Email</small>
                            <br />
                            <small class="text-muted">@note.TimeAt s</small>
                            <p class="mb-0">@note.Comment</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No comments yet.</p>
                }
            </div>
            <!-- Comment Tab -->
            <div class="tab-pane fade" id="comment-pane" role="tabpanel" aria-labelledby="comment-tab">
                <form method="post" asp-controller="Search" asp-action="Create" id="commentForm">
                    <input type="hidden" name="youtubeUrl" value="@Context.Request.Query["url"]" />
                    <input type="hidden" name="timeAt" id="timeAtInput" value="0" />
                    <div class="mb-3">
                        <label for="commentInput" class="form-label">Add a comment</label>
                        <textarea class="form-control" id="commentInput" name="comment" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Submit</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .comment-marker {
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }
    .comment-marker.active-comment {
        background-color: #fff3cd;
        border-color: #ffc107 !important;
    }
</style>

@{
    var currentUserEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}

@if (!string.IsNullOrEmpty(videoId))
{
    <script src="https://www.youtube.com/iframe_api"></script>
    <script>
        var currentUserEmail = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(currentUserEmail))';
    </script>
    <script>
        var player;
        var timeInterval = null;

        function highlightCurrentComment() {
            if (!player || typeof player.getCurrentTime !== 'function') return;
            var currentTime = Math.floor(player.getCurrentTime());

            document.querySelectorAll('.comment-marker').forEach(function (el) {
                var t = parseInt(el.getAttribute('data-time'), 10);
                if (t === currentTime) {
                    el.classList.add('active-comment');
                } else {
                    el.classList.remove('active-comment');
                }
            });
        }

        function startTracking() {
            if (!timeInterval) {
                timeInterval = setInterval(highlightCurrentComment, 1000);
            }
        }

        function stopTracking() {
            clearInterval(timeInterval);
            timeInterval = null;
        }

        function onPlayerStateChange(event) {
            if (event.data === YT.PlayerState.PLAYING) {
                startTracking();
            } else {
                stopTracking();
            }
        }

        function onYouTubeIframeAPIReady() {
            player = new YT.Player('ytplayer', {
                videoId: '@videoId',
                playerVars: { 'autoplay': 0 },
                events: { 'onStateChange': onPlayerStateChange }
            });
        }

        document.getElementById('commentForm').addEventListener('submit', function (e) {
            e.preventDefault();

            if (player && typeof player.getCurrentTime === 'function') {
                document.getElementById('timeAtInput').value = Math.floor(player.getCurrentTime());
            }

            var form = this;
            var formData = new URLSearchParams(new FormData(form));

            fetch(form.action, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: formData
            })
            .then(function (res) { return res.json(); })
            .then(function (data) {
                var viewPane = document.getElementById('view-pane');
                var placeholder = viewPane.querySelector('p.text-muted');
                if (placeholder) placeholder.remove();

                var div = document.createElement('div');
                div.className = 'mb-2 p-2 border rounded comment-marker';
                div.setAttribute('data-time', data.timeAt);
                div.setAttribute('data-email', data.email);
                div.innerHTML = '<small class="text-muted fw-bold">' + data.email + '</small>'
                              + '<br />'
                              + '<small class="text-muted">' + data.timeAt + ' s</small>'
                              + '<p class="mb-0">' + data.comment + '</p>';
                viewPane.appendChild(div);

                document.getElementById('commentInput').value = '';

                new bootstrap.Tab(document.getElementById('view-tab')).show();
                applyNoteFilter();
            });
        });

        function applyNoteFilter() {
            var myOnly = document.getElementById('myNotesOnly').checked;
            document.querySelectorAll('#view-pane .comment-marker').forEach(function (el) {
                if (myOnly && el.getAttribute('data-email') !== currentUserEmail) {
                    el.style.display = 'none';
                } else {
                    el.style.display = '';
                }
            });
        }

        document.getElementById('myNotesOnly').addEventListener('change', applyNoteFilter);
    </script>
}
