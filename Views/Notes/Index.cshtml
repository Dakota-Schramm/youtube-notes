@model IEnumerable<youtube_notes.Models.Note>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Comment)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.YoutubeId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TimeAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Comment)
            </td>
            <td>
                <a asp-controller="Search" asp-action="Index" asp-route-url="@($"https://www.youtube.com/watch?v={item.YoutubeId}")">@Html.DisplayFor(modelItem => item.YoutubeId)</a>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TimeAt)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
